# --- Next.js (apps/web) ---
# NestJS API base URL for server-side calls
API_URL=http://localhost:4001/api
# NestJS API base URL exposed to browser direct calls
NEXT_PUBLIC_API_URL=http://localhost:4001/api
# Same secret as apps/api JWT_SECRET — used by middleware (proxy) to verify access_token
JWT_SECRET=change-me-access-secret-min-32-chars

# --- NestJS API (apps/api) — see apps/api/.env.example ---
# DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET, FRONTEND_URL, PORT

# --- Docker Compose (root) ---
# DB_PASSWORD, JWT_SECRET, JWT_REFRESH_SECRET, FRONTEND_URL

# --- Other ---
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-cloudflare-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-cloudflare-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=your-cloudflare-r2-bucket-name
RESEND_API_KEY=your-resend-api-key
CRON_SECRET=your-cron-secret

{
  "name": "squademy",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed-root": "yarn workspace @squademy/database db:seed-root",
    "deploy:api": "fly deploy --config apps/api/fly.toml --dockerfile apps/api/Dockerfile",
    "db:proxy": "fly proxy 5433:5432 -a squademy-db"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}

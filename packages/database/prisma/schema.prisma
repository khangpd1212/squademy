generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?   @map("password_hash")
  displayName  String    @map("display_name")
  fullName     String?   @map("full_name")
  avatarUrl    String?   @map("avatar_url")
  school       String?
  location     String?
  age          Int?
  acceptPrivacyAt DateTime? @map("accept_privacy_at")
  refreshToken String?   @map("refresh_token")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  createdGroups       Group[]            @relation("GroupCreator")
  memberships         GroupMember[]
  sentInvitations     GroupInvitation[]   @relation("InvitedBy")
  receivedInvitations GroupInvitation[]   @relation("Invitee")
  lessons             Lesson[]
  flashcardDecks      FlashcardDeck[]
  reviewComments      ReviewComment[]
  lessonReactions    LessonReaction[]
  lessonProgresses   LessonProgress[]
  srsProgresses      SRSProgress[]
  aliveTextInteractions AliveTextInteraction[]
  createdExercises  Exercise[]        @relation("ExerciseCreator")
  exerciseSubmissions ExerciseSubmission[]

  @@map("users")
}

model Group {
  id                   String   @id @default(uuid())
  name                 String
  description          String?
  inviteCode           String   @unique @map("invite_code")
  exerciseDeadlineDay  Int?     @map("exercise_deadline_day")
  exerciseDeadlineTime String?  @map("exercise_deadline_time")
  isDeleted            Boolean  @default(false) @map("is_deleted")
  createdBy            String   @map("created_by")
  createdAt            DateTime @default(now()) @map("created_at")

  creator     User              @relation("GroupCreator", fields: [createdBy], references: [id])
  members     GroupMember[]
  invitations GroupInvitation[]
  lessons     Lesson[]
  exercises   Exercise[]
  learningPathItems LearningPathItem[]

  @@map("groups")
}

model GroupMember {
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")
  isDeleted Boolean  @default(false) @map("is_deleted")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

model GroupInvitation {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  invitedBy String   @map("invited_by")
  inviteeId String   @map("invitee_id")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User  @relation("InvitedBy", fields: [invitedBy], references: [id])
  invitee User  @relation("Invitee", fields: [inviteeId], references: [id])

  @@unique([groupId, inviteeId, status])
  @@map("group_invitations")
}

model Lesson {
  id              String   @id @default(uuid())
  groupId         String   @map("group_id")
  authorId        String   @map("author_id")
  title           String
  content         Json?
  contentMarkdown String?  @map("content_markdown")
  status          String   @default("draft")
  editorFeedback  String?  @map("editor_feedback")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])
  exercises Exercise[]
  reviewComments ReviewComment[]
  reactions LessonReaction[]
  progress  LessonProgress[]
  aliveTextInteractions AliveTextInteraction[]
  learningPathItems LearningPathItem[]

  @@map("lessons")
}

model ReviewComment {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  userId    String   @map("user_id")
  lineRef   String   @map("line_ref")
  body      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  lesson   Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [userId], references: [id])
  parent   ReviewComment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies  ReviewComment[] @relation("CommentReplies")

  @@map("review_comments")
  @@index([lessonId, lineRef])
  @@index([parentId])
}

model Exercise {
  id               String    @id @default(uuid())
  title            String?
  type             String
  groupId          String    @map("group_id")
  lessonId         String?   @map("lesson_id")
  createdById      String?   @map("created_by_id")
  payload          Json?
  isGroupChallenge Boolean   @default(false) @map("is_group_challenge")
  isDeleted        Boolean   @default(false) @map("is_deleted")
  scheduledAt      DateTime? @map("scheduled_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  group       Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  lesson      Lesson?             @relation(fields: [lessonId], references: [id])
  createdBy   User?               @relation("ExerciseCreator", fields: [createdById], references: [id])
  questions   ExerciseQuestion[]
  submissions ExerciseSubmission[]

  @@index([groupId])
  @@map("exercises")
}

model ExerciseQuestion {
  id         String   @id @default(uuid())
  exerciseId String   @map("exercise_id")
  type       String   // 'mcq', 'fill_blank', 'cloze', 'dictation', 'ipa_to_word'
  prompt     String
  options    Json?    // Array for MCQ: [{ label, value }]
  answers    Json?    // Array for Cloze/multiple answers
  audioUrl   String?  @map("audio_url")
  ipa        String?
  order      Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@map("exercise_questions")
}

model ExerciseSubmission {
  id           String    @id @default(uuid())
  exerciseId   String    @map("exercise_id")
  userId       String    @map("user_id")
  answers      Json      // [{ questionId, answer, isCorrect }]
  score        Float?
  correctCount Int?      @map("correct_count")
  totalCount   Int?      @map("total_count")
  timeTaken    Int       @map("time_taken") // Seconds
  focusEvents  Json?     @map("focus_events") // [{ type: 'blur' | 'focus', timestamp }]
  submittedAt  DateTime  @default(now()) @map("submitted_at")

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([exerciseId, userId])
  @@map("exercise_submissions")
}

model FlashcardDeck {
  id          String   @id @default(cuid())
  title       String
  description String?
  authorId    String   @map("author_id")
  status      String   @default("draft")
  cardCount   Int      @default(0) @map("card_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  author  User             @relation(fields: [authorId], references: [id])
  cards   FlashcardCard[]
  srsProgress SRSProgress[]
  learningPathItems LearningPathItem[]

  @@map("flashcard_decks")
}

model FlashcardCard {
  id              String   @id @default(cuid())
  deckId          String   @map("deck_id")
  front           String
  back            String?
  pronunciation   String?
  audioUrl        String?  @map("audio_url")
  exampleSentence String?  @map("example_sentence")
  imageUrl        String?  @map("image_url")
  tags            Json?
  extraNotes      String?  @map("extra_notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  deck        FlashcardDeck  @relation(fields: [deckId], references: [id], onDelete: Cascade)
  srsProgress SRSProgress[]

  @@map("flashcard_cards")
}

model SRSProgress {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  deckId        String   @map("deck_id")
  cardId        String   @map("card_id")
  grade         Int       @default(0)
  nextReviewDate DateTime? @map("next_review_date")
  lastReviewDate DateTime? @map("last_review_date")
  interval      Int       @default(1)
  easeFactor    Float     @default(2.5) @map("ease_factor")
  repetitions   Int       @default(0) @map("repetitions")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card FlashcardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, nextReviewDate])
  @@map("srs_progress")
}

model LearningPathItem {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  lessonId  String?  @map("lesson_id")
  deckId    String?  @map("deck_id")
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group  Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id])
  deck   FlashcardDeck? @relation(fields: [deckId], references: [id])

  @@map("learning_path_items")
  @@index([groupId, sortOrder])
  @@unique([groupId, deckId])
  @@unique([groupId, lessonId])
}

model LessonReaction {
  id           String   @id @default(uuid())
  lessonId     String   @map("lesson_id")
  userId       String   @map("user_id")
  lineRef      String   @map("line_ref")
  reactionType String   @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("lesson_reactions")
  @@unique([lessonId, userId, lineRef, reactionType])
  @@index([lessonId, lineRef])
}

model LessonProgress {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  userId    String   @map("user_id")
  isRead    Boolean  @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("lesson_progress")
  @@unique([lessonId, userId])
}

model AliveTextInteraction {
  id             String   @id @default(uuid())
  lessonId       String   @map("lesson_id")
  userId         String   @map("user_id")
  blockId        String   @map("block_id")
  interactionType String  @map("interaction_type")
  createdAt      DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@map("alive_text_interactions")
  @@unique([lessonId, userId, blockId])
  @@index([lessonId])
}

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/database-name

# JWT (must match apps/web JWT_SECRET for middleware verification)
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# CORS / cookies
FRONTEND_URL=http://localhost:4000

# HTTP port (default 3001)
PORT=8080
